{
  "name": "python-backend",
  "version": "1.0.0",
  "description": "Python backend for POS application",
  "scripts": {
    "dev": "./dev.sh",
    "build": "echo 'Python backend does not require build step'",
    "lint": "bash -c 'source venv/bin/activate && python -m pylint src/'",
    "type-check": "bash -c 'source venv/bin/activate && python -m mypy src/'",
    "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true"
  }
}

